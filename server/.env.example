# ============================================
# AI Voice Agent - Environment Configuration
# ============================================

# Server
PORT=3001
NODE_ENV=development

# Bolna AI Configuration
BOLNA_API_KEY=your_bolna_api_key_here
BOLNA_BASE_URL=https://api.bolna.ai

# Phone Number (Indian - provisioned via Bolna)
BOLNA_PHONE_NUMBER=+91XXXXXXXXXX

# Webhook URL (your public server URL for Bolna callbacks)
# Use ngrok or similar for local development: https://xxxx.ngrok.io/api/webhooks/bolna
WEBHOOK_BASE_URL=http://localhost:3001

# Campaign Settings
MAX_CONCURRENT_CALLS=5
CALL_RETRY_ATTEMPTS=2
CALL_RETRY_DELAY_MS=30000

# Default Language (english | hindi | hinglish)
DEFAULT_LANGUAGE=hinglish

# Default Dealer Info (can be overridden per campaign)
DEFAULT_DEALER_NAME=AutoCare Service Center
DEFAULT_DEALER_ADDRESS=MG Road, Bengaluru
DEFAULT_DEALER_PHONE=+919876543210

# OpenAI API Key (required for test agent chat + auto-test)
OPENAI_API_KEY=sk-...

# ElevenLabs — direct API (required for voice testing in browser)
# Get from: ElevenLabs Dashboard → Profile → API Keys
ELEVENLABS_API_KEY=
# Get voice_id from: ElevenLabs Dashboard → Voices → click voice → copy ID
# Recommended: Riya K. Rao (Indian accent) on eleven_multilingual_v2
ELEVENLABS_VOICE_ID=
ELEVENLABS_VOICE_NAME=Riya K. Rao
